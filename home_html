<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Harmoni Nusantara - Content</title>
    <link href="https://fonts.googleapis.com/css2?family=Cinzel:wght@400;700&family=Montserrat:wght@300;400;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="style.css">
    <style>
        body, html { margin: 0; padding: 0; overflow: hidden; width: 100%; height: 100%; }

        .bg-container {
            position: fixed; top: 0; left: 0; width: 100vw; height: 100vh; z-index: -100;
            background-image: url('https://wallpaperaccess.com/full/21963.jpg');
            background-size: cover; background-position: center; filter: brightness(0.5);
        }

        .container { background-color: transparent !important; }

        /* Tombol Triggger Kembali Sinematik Menggantikan Teks Biasa */
        .btn-back-trigger {
            background: none; border: none; outline: none; padding: 0;
            font-family: 'Cinzel', serif; font-size: inherit; font-weight: inherit;
            color: inherit; text-align: left; cursor: pointer;
            transition: color 0.3s ease, letter-spacing 0.3s ease;
        }
        .btn-back-trigger:hover {
            color: #f5cf66 !important; letter-spacing: 2px;
        }
    </style>
</head>
<body>

    <div class="bg-container"></div>

    <section class="container">
        <header class="header">
            <div class="name">
                <button type="button" class="btn-back-trigger" onclick="if(window.parent && window.parent.tutupGerbang){ window.parent.tutupGerbang(); }">← FELL DEVELOPER</button>
            </div>
            <div class="class">INDONESIA</div>
        </header>

        <div class="judulharmoninusantara">
            <span class="top-tagline">NATURE WORLD OF INDONESIA</span>
            <h1 class="main-title">HARMONI<br>NUSANTARA</h1>
            <div class="unity-badge">BHINNEKA TUNGGAL IKA</div>
        </div>

        <nav class="bottom-menu">
            <a href="javascript:void(0);" class="nav-card" style="--bg-url: url('https://png.pngtree.com/thumb_back/fh260/background/20240912/pngtree-borobudur-temple-at-sunrise-with-mountain-view-in-indonesia-image_16166646.jpg')">
                <span class="label">Pemandangan</span>
                <span class="sub">Bentang Alam Megah</span>
            </a>
            <a href="javascript:void(0);" class="nav-card" style="--bg-url: url('https://blogger.googleusercontent.com/img/b/R29vZ2xl/AVvXsEj0FRMr1TdZBc4pdrPKi4_V8uNWUJu523W9SdAZZRCT5-HMAmQanplHjUTtKBAV5W9kvDSq6I7M7breI6mgC7ueDxjpoXD0U6P9lyx-HyAGcKNgjGUnd8kEwhOg9J-xXM8u4Gm8cUjj02c2/s1600/wayang.jpg')">
                <span class="label">Budaya</span>
                <span class="sub">Tradisi & Warisan</span>
            </a>
            <a href="javascript:void(0);" class="nav-card" style="--bg-url: url('https://millionbloom.com/cdn/shop/articles/20_Daftar_Nama_nama_Bunga_di_Indonesia_yang_Sangat_Langka_1500x.jpg?v=1712050485')">
                <span class="label">Flora</span>
                <span class="sub">Eksotisme Tanaman</span>
            </a>
            <a href="javascript:void(0);" class="nav-card" style="--bg-url: url('https://lister.co.id/wp-content/uploads/2023/08/Peta-Persebaran-Flora-dan-Fauna-di-Indonesia-Ada-3-Jenis.jpg')">
                <span class="label">Fauna</span>
                <span class="sub">Satwa Endemik</span>
            </a>
            <a href="javascript:void(0);" class="nav-card" style="--bg-url: url('https://www.jakartamu.com/wp-content/uploads/2024/12/map-of-indonesia-large-1068x610-1.jpg')">
                <span class="label">Sejarah</span>
                <span class="sub">Warisan Hidup</span>
            </a>
        </nav>
    </section>

    <script>
        document.addEventListener('keydown', function(event) {
            if (event.key === 'Escape') {
                if(window.parent && typeof window.parent.tutupGerbang === 'function') {
                    window.parent.tutupGerbang();
                }
            }
        });
    </script>
    <script src="home_script.js"></script>
</body>
</html>
